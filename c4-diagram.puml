@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title OmniPDF Translate - Minimal Release (Translation Pipeline Only)

Person(user, "User", "User accessing OmniPDF Translate via browser")

System_Boundary(omnipdf, "OmniPDF Translate System") {

  Container(nginx, "API Gateway", "Nginx", "Routes requests to frontend and API, handles file uploads (100MB limit)")

  Container(frontend, "Streamlit Frontend", "Python/Streamlit", "Web UI with Upload and Translate pages")

  Container(pdf_service, "PDF Processor Service", "FastAPI", "Central orchestrator - manages sessions, coordinates translation workflows")

  Container(pdf_extraction, "PDF Extraction Service", "FastAPI + docling", "Extracts text and structure from PDFs using docling")

  Container(docling_translate, "Docling Translation Service", "FastAPI", "Translates docling JSON structures using LLM")

  Container(pdf_renderer, "PDF Renderer Service", "FastAPI", "Overlays translated content onto original PDFs")

  ContainerDb(minio, "MinIO", "Object Storage (S3)", "Stores PDFs, extracted JSON, translated content")

  ContainerDb(redis, "Redis", "Session Store", "Session management and file tracking")
}

System_Boundary(external_ai, "External AI Infrastructure") {
  Container(vllm_text, "vLLM Text Model", "vLLM Server", "External text LLM for translation")
}

' User interactions
Rel(user, nginx, "HTTPS requests", "Upload PDFs, request translations")

' Nginx routing
Rel(nginx, frontend, "Routes UI requests", "Port 8501")
Rel(nginx, pdf_service, "Routes API requests", "Port 8000")

' Frontend to backend
Rel(frontend, pdf_service, "API calls", "Upload documents, check status, get presigned URLs")

' Translation pipeline workflow
Rel(pdf_service, pdf_extraction, "Extract PDF content", "Sends PDF URL, receives docling JSON")
Rel(pdf_service, docling_translate, "Translate content", "Sends docling JSON + languages")
Rel(pdf_service, pdf_renderer, "Render translated PDF", "Sends translated docling JSON")

' File storage operations
Rel(pdf_service, minio, "Store uploaded PDFs", "S3 API")
Rel(pdf_extraction, minio, "Store extracted JSON + job status", "S3 API")
Rel(docling_translate, minio, "Store translated JSON + job status", "S3 API")
Rel(pdf_renderer, minio, "Store rendered PDFs + presigned URLs", "S3 API")

' External AI communication
Rel(docling_translate, vllm_text, "Translation requests", "HTTP/HTTPS")

' Session and job status management
Rel(pdf_service, redis, "Session validation + file tracking", "Redis protocol")
Rel(pdf_extraction, redis, "Document file list management", "Redis protocol")
Rel(docling_translate, redis, "Document file list management", "Redis protocol")

SHOW_LEGEND()

note right of omnipdf
  **Minimal Translation Pipeline:**
  1. User uploads PDF via frontend
  2. PDF Processor stores PDF in MinIO
  3. PDF Extraction extracts structure
  4. Translation service translates content
  5. Renderer creates translated PDF
  6. User downloads via presigned URL

  **Removed Services:**
  - Embedder (no vector storage)
  - ChromaDB (no embeddings)
  - Image Captioner (no captions)
  - Metadata Service (no metadata)
  - Cleaner (manual cleanup)
end note

@enduml
