# MinIO / S3-compatible storage
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=omnifiles
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
REDIS_URL="redis://redis:6379/0?decode_responses=True&protocol=3"
IMAGE_CAPTIONER_URL=http://image_captioner_service:8000/image_captioner

# GPU Configuration
# Set to "true" to use GPU acceleration, "false" to use CPU only
USE_GPU=false

# Timezone configuration
TZ=Asia/Singapore
