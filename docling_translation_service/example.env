# MinIO / S3-compatible storage
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=omnifiles
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Default LLM configuration (fallback for unsupported languages)
# Base URL without the /v1/chat/completions endpoint (added automatically in code)
LLM_API_TOKEN=token-abc123
LLM_BASE_URL=http://webworkdgx/vllm_default
LLM_MODEL=Gemma2-9B-Default-Model

# Language-specific LLM configurations
# Format: LLM_<LANGUAGE>_BASE_URL, LLM_<LANGUAGE>_MODEL, LLM_<LANGUAGE>_API_TOKEN
# Base URLs should NOT include /v1/chat/completions (added automatically)

# Bahasa Indonesia
LLM_INDONESIAN_BASE_URL=http://webworkdgx/vllm_sealion
LLM_INDONESIAN_MODEL=Gemma2-9B-Sealion-V3-Instruct
LLM_INDONESIAN_API_TOKEN=token-abc123

# Bahasa Melayu (Malay)
LLM_MALAY_BASE_URL=http://webworkdgx/vllm_sealion
LLM_MALAY_MODEL=Gemma2-9B-Sealion-V3-Instruct
LLM_MALAY_API_TOKEN=token-abc123

# Chinese (Simplified/Traditional)
LLM_CHINESE_BASE_URL=http://webworkdgx/vllm_qwen3coder
LLM_CHINESE_MODEL=Qwen3-Coder-30B-A3B-Instruct
LLM_CHINESE_API_TOKEN=token-abc123

REDIS_URL="redis://redis:6379/0?decode_responses=True&protocol=3"

# Timezone configuration
TZ=Asia/Singapore

# LLM Concurrency settings
LLM_CONCURRENCY=5
