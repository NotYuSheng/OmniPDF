OPENAI_BASE_URL=http://webworkdgx/vllm_qwen3coder/v1 # DGX URL
OPENAI_API_KEY=lm-studio

# Qwen-2.5 Model Configuration
OPENAI_MODEL=Qwen2.5-14B-Coder-Instruct
QWEN_TEMPERATURE=0.1
QWEN_MAX_TOKENS=2000
QWEN_TOP_K=5
QWEN_TOP_P=0.8
QWEN_FREQ_PENALTY=0.1
QWEN_PRESENCE_PENALTY=0.1

# Context Management
QWEN_MAX_CONTEXT=4000
QWEN_MIN_SIMILARITY=0.3
QWEN_ENABLE_RERANKING=true

# RAG Optimization
ENABLE_LLM_QUERY_CLASSIFICATION=true
ENABLE_RESPONSE_POST_PROCESSING=true
