OPENAI_BASE_URL=http://localhost:1234/v1 # Please change this to your LM Studio URL
OPENAI_API_KEY=lm-studio

# Qwen-2.5 Model Configuration
OPENAI_MODEL=Qwen2.5-14B-Coder-Instruct
QWEN_TEMPERATURE=0.1
QWEN_MAX_TOKENS=2000
QWEN_TOP_P=0.8
QWEN_FREQ_PENALTY=0.1
QWEN_PRESENCE_PENALTY=0.1

# Context Management
QWEN_MAX_CONTEXT=4000
QWEN_MIN_SIMILARITY=0.3
QWEN_ENABLE_RERANKING=true

# RAG Optimization
ENABLE_QUERY_TYPE_DETECTION=true
ENABLE_RESPONSE_POST_PROCESSING=true

# MinIO / S3-compatible storage
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=omnifiles
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Redis storage
REDIS_URL="redis://redis:6379/0?decode_responses=True&protocol=3"